{
  "name": "cc2-mcp",
  "version": "1.1.0",
  "description": "MCP Server for Cocos Creator 2.x editor — let AI assistants control scenes, nodes, components and assets via MCP protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cc2-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "cc-extension",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "cocos-creator",
    "cocos2d",
    "editor",
    "ai",
    "model-context-protocol"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest --run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ws": "^8.16.0",
    "zod": "^3.22.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "@types/uuid": "^9.0.0",
    "vitest": "^1.6.0"
  }
}
